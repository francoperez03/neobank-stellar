# Server
PORT=4000
LOG_LEVEL=info

# CORS
WEB_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=neobank
DB_PASSWORD=          # required
DB_NAME=neobank_stellar

CROSSMINT_PROJECT_ID=f1435812-bce1-42a5-9a04-0fe35f49c1d2

# Crossmint server-side wallet API (transactions + approvals). Server-side only —
# distinct from the browser VITE_CROSSMINT_API_KEY. The server key signs vault
# deposits/withdrawals on the user's behalf and must be a signer on their wallet.
CROSSMINT_API_BASE_URL=https://staging.crossmint.com/api/2025-06-09
CROSSMINT_SERVER_API_KEY=
# Stellar secret key (S...) of the server signer.
STELLAR_SERVER_KEY=

# DeFindex (yield vaults) — read-only here (APY + balance). Key must stay
# server-side. Get a key at https://api.defindex.io/register. 503 until set.
DEFINDEX_API_URL=https://api.defindex.io
DEFINDEX_API_KEY=
DEFINDEX_NETWORK=testnet
# Default below is the BlendUSDC testnet vault; override per deployment.
DEFINDEX_VAULT_ADDRESS=CAQCFVLOBK5GIULPNZRGATJJMIZL5BSP7X5YJVMGCPTUEPFM4AVSRCJU