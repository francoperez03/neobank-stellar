# staging | production
CROSSMINT_ENV=staging

# Server-side Crossmint API key. Distinct from the frontend's
# VITE_CROSSMINT_API_KEY — never expose this one to the browser.
CROSSMINT_SERVER_API_KEY=

# Shared secret used to verify incoming webhook signatures from Crossmint.
CROSSMINT_WEBHOOK_SECRET=

PORT=4000

# apps/web's vite.config.ts pins the dev server to :3000, not Vite's default :5173.
WEB_ORIGIN=http://localhost:3000

DB_PATH=./photon.db
LOG_LEVEL=info
